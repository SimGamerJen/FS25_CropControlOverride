<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="CropControlOverrideMenu" onOpen="onOpen" onClose="onClose" onCreate="onCreate" onEscPressed="onClickBack">
    <Bitmap profile="fs25_fullScreenBackground" id="background" imageColor="0.01681 0.01764 0.016 0.98"/>
    <Bitmap profile="baseReference" position="80px 78px" size="1760px 895px" imageColor="0.025 0.028 0.025 0.92"/>

    <GuiElement profile="fs25_menuContainer">
        <GuiElement profile="fs25_menuHeaderPanel">
            <Bitmap profile="fs25_menuHeaderIconBg">
                <Bitmap profile="fs25_menuHeaderIcon" imageSliceId="gui.contracts"/>
            </Bitmap>
            <Text profile="fs25_menuHeaderTitle" id="titleElement" text="CROP CONTROL OVERRIDE"/>
            <Button profile="ccoHelpIconButton" position="1560px -6px" text="?" onClick="onClickHelp" id="helpIconButton"/>
        </GuiElement>

        <BoxLayout profile="fs25_subCategorySelectorTabbedBox" id="subCategoryBox">
            <Button profile="fs25_subCategorySelectorTabbedTab" id="subCategoryTabs[1]" text="STATUS" onClick="onClickStatus">
                <ThreePartBitmap profile="fs25_subCategorySelectorTabbedTabBg" name="background"/>
            </Button>
            <Button profile="fs25_subCategorySelectorTabbedTab" id="subCategoryTabs[2]" text="ALL RULES" onClick="onClickRules">
                <ThreePartBitmap profile="fs25_subCategorySelectorTabbedTabBg" name="background"/>
            </Button>
            <Button profile="fs25_subCategorySelectorTabbedTab" id="subCategoryTabs[3]" text="DISABLED" onClick="onClickDisabled">
                <ThreePartBitmap profile="fs25_subCategorySelectorTabbedTabBg" name="background"/>
            </Button>
            <Button profile="fs25_subCategorySelectorTabbedTab" id="subCategoryTabs[4]" text="LIMITED" onClick="onClickLimited">
                <ThreePartBitmap profile="fs25_subCategorySelectorTabbedTabBg" name="background"/>
            </Button>
            <Button profile="fs25_subCategorySelectorTabbedTab" id="subCategoryTabs[5]" text="NPC BLOCKED" onClick="onClickBlockedRules">
                <ThreePartBitmap profile="fs25_subCategorySelectorTabbedTabBg" name="background"/>
            </Button>
            <Button profile="fs25_subCategorySelectorTabbedTab" id="subCategoryTabs[6]" text="VALIDATION" onClick="onClickValidate">
                <ThreePartBitmap profile="fs25_subCategorySelectorTabbedTabBg" name="background"/>
            </Button>
        </BoxLayout>
        <ThreePartBitmap profile="fs25_lineSeparatorTopHighlighted" position="0px -57px"/>
        <MultiTextOption profile="fs25_subCategorySelectorTabbed" id="subCategoryPaging" position="0px -10px" onClick="updateSubCategoryPages"/>

        <GuiElement profile="fs25_subCategorySelectorTabbedContainer" id="ccoMainPage">
            <Bitmap position="-20px 34px" size="1525px 615px" imageColor="0.015 0.017 0.015 0.28"/>
            <Text text="Read-only crop policy view | Use the tabs or PREV TAB / NEXT TAB to switch sections" position="0px 12px" size="1480px 25px" textSize="15px" textColor="0.55 0.63 0.50 1" textVerticalAlignment="middle" textAlignment="left"/>

            <Text id="bodyTextElement" text="" position="40px -20px" size="1480px 610px" textSize="16px" textColor="0.88 0.90 0.86 1" textVerticalAlignment="top" textAlignment="left" textMaxNumLines="28"/>

            <GuiElement id="ruleTableContainer" visible="false">
                <GuiElement profile="fs25_statisticsHeaderBox" position="0px -18px" size="1520px 38px">
                    <Text profile="ccoColumnHeader" position="20px -3px"   size="240px 34px" text="Crop Type"/>
                    <Text profile="ccoColumnHeader" position="275px -3px"  size="210px 34px" text="Player Permitted"/>
                    <Text profile="ccoColumnHeader" position="500px -3px"  size="190px 34px" text="NPC Permitted"/>
                    <Text profile="ccoColumnHeader" position="710px -3px"  size="180px 34px" text="Max Field (ha)"/>
                    <Text profile="ccoColumnHeader" position="910px -3px"  size="120px 34px" text="Loaded"/>
                    <Text profile="ccoColumnHeader" position="1050px -3px" size="240px 34px" text="Status"/>
                </GuiElement>

                <SmoothList id="ruleList" profile="ccoRulesList" position="0px -70px" size="1520px 597px" listItemSpacing="-1px">
                    <ListItem profile="ccoRulesListItem">
                        <ThreePartBitmap profile="ccoListItemGradient" name="alternating"/>
                        <Text profile="ccoRowCellLeft"   position="20px 0px"   size="240px 34px" name="cellCrop"/>
                        <Text profile="ccoRowCellCenter" position="275px 0px"  size="210px 34px" name="cellEnabled"/>
                        <Text profile="ccoRowCellCenter" position="500px 0px"  size="190px 34px" name="cellNpc"/>
                        <Text profile="ccoRowCellCenter" position="710px 0px"  size="180px 34px" name="cellMaxHa"/>
                        <Text profile="ccoRowCellCenter" position="910px 0px"  size="120px 34px" name="cellLoaded"/>
                        <Text profile="ccoRowCellCenter" position="1050px 0px" size="240px 34px" name="cellStatus"/>
                    </ListItem>
                </SmoothList>

                <ThreePartBitmap profile="ccoSliderBox" position="1560px -70px" size="6px 597px" id="ruleListSliderBox">
                    <Slider profile="fs25_listSlider" dataElementId="ruleList"/>
                </ThreePartBitmap>

                <Text id="emptyStateText" profile="ccoEmptyStateText" position="474px -230px" text="No matching crop rules." visible="false"/>
            </GuiElement>
        </GuiElement>

        <BoxLayout profile="fs25_dialogButtonBox">
            <Button profile="buttonMenuPrev" text="PREV TAB" onClick="onPagePrevious" id="prevTabButton"/>
            <Button profile="buttonMenuNext" text="NEXT TAB" onClick="onPageNext" id="nextTabButton"/>
            <Button profile="buttonExtra1" text="RELOAD" onClick="onClickReload" id="reloadButton"/>
            <Button profile="buttonBack" text="$l10n_button_back" onClick="onClickBack" id="backButton"/>
        </BoxLayout>
    </GuiElement>
</GUI>
