        <fruit name="RICE"           enabled="true" npcAllowed="mapDefault" npcMaxHa="0"  resetNpcFields="true"/>
        <fruit name="RICELONGGRAIN"  enabled="true" npcAllowed="mapDefault" npcMaxHa="0"  resetNpcFields="true"/>
