        <fruit name="ONION"          enabled="true" npcAllowed="mapDefault" npcMaxHa="10" resetNpcFields="true"/>
        <fruit name="GREENBEAN"      enabled="true" npcAllowed="mapDefault" npcMaxHa="10" resetNpcFields="true"/>
        <fruit name="PEA"            enabled="true" npcAllowed="mapDefault" npcMaxHa="10" resetNpcFields="true"/>
